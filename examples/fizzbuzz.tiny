// FizzBuzz — prints 1..20, "Fizz" for multiples of 3,
// "Buzz" for multiples of 5, "FizzBuzz" for both.

for (let i = 1; i <= 20; i = i + 1) {
    if (i % 15 == 0) {
        print("FizzBuzz");
    } else {
        if (i % 3 == 0) {
            print("Fizz");
        } else {
            if (i % 5 == 0) {
                print("Buzz");
            } else {
                print(i);
            }
        }
    }
}
